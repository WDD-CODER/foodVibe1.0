{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(grep:*)",
      "Bash(xargs grep:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git checkout:*)",
      "Bash(npm test:*)",
      "Bash(npx ng:*)",
      "Bash(npx tsc:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(while read:*)",
      "Bash(do wc:*)",
      "Bash(done)",
      "Skill(update-config)",
      "Bash(npm start:*)",
      "Bash(gh pr:*)",
      "Bash(gh auth:*)",
      "Bash(rm -rf .claude/worktrees/fix/duplicate-name-validation-venues-suppliers)",
      "Bash(git worktree:*)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'BRANCH=$(git branch --show-current 2>/dev/null); if [ -z \"$BRANCH\" ] || [ \"$BRANCH\" = \"main\" ] || [ \"$BRANCH\" = \"master\" ]; then exit 0; fi; COUNT=$(git status --porcelain 2>/dev/null | wc -l | tr -d \" \"); if [ \"$COUNT\" -gt \"0\" ]; then printf \"\\n========================================\\n  WORKTREE REMINDER\\n  Branch : %s\\n  Changed: %s file(s) uncommitted\\n  Say: end session  to commit+merge+cleanup\\n========================================\\n\\n\" \"$BRANCH\" \"$COUNT\"; fi'"
          }
        ]
      }
    ]
  }
}
