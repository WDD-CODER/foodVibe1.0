{
  "name": "food-vibe1.0",
  "version": "0.1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "log-server": "node scripts/log-server.js",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "lint:icons": "node scripts/check-lucide-icons.mjs",
    "lint:no-native-select": "node scripts/check-no-native-select.mjs",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "build:render": "npx ng build --configuration=production",
    "dev:local": "ng serve -c local",
    "dev:remote": "ng serve -c remote",
    "repair:backup": "node scripts/backup-before-repair.mjs",
    "repair:diagnose": "node scripts/diagnose-broken-refs.mjs",
    "repair:refs": "node scripts/repair-recipe-references.mjs",
    "build:gh-pages": "ng build --configuration=gh-pages",
    "deploy:gh-pages": "npm run build:gh-pages && npx gh-pages -d dist/food-vibe1.0/browser",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/app/**/*.{ts,html}\"",
    "lint:fix": "eslint --fix --no-error-on-unmatched-pattern \"src/app/**/*.{ts,html}\"",
    "prepare": "husky"
  },
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@angular/animations": "^19.2.21",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.21",
    "exceljs": "^4.4.0",
    "lucide-angular": "^0.563.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.19",
    "@angular-eslint/builder": "^19.8.1",
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular-eslint/eslint-plugin-template": "^19.8.1",
    "@angular-eslint/template-parser": "^19.8.1",
    "@angular/cli": "^19.2.19",
    "@angular/compiler-cli": "^19.2.21",
    "@playwright/test": "^1.49.0",
    "@types/jasmine": "~5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.5",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.6",
    "prettier": "^3.9.5",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.63.0"
  }
}
