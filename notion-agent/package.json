{
  "name": "notion-agent",
  "version": "0.1.0",
  "description": "Personal Notion Assistant — autonomous Claude Code project for natural-language Notion workspace management.",
  "private": true,
  "type": "commonjs",
  "main": "src/notion-client.js",
  "scripts": {
