# See https://docs.github.com/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# Compiled output
/dist
/tmp
/out-tsc
/bazel-out

# Node
/node_modules
server/node_modules
npm-debug.log
yarn-error.log

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/*

# Log files (dev log server)
/logs/

# Miscellaneous
/.angular/cache
.sass-cache/
/connect.lock
/coverage
/libpeerconnection.log
testem.log
/typings

# Worktree port assignment
.worktree-port
# Worktree remote cleanup breadcrumb (processed by github-sync on next main session)
.worktree-cleanup

# Claude Code local config (never commit)
.claude/settings.local.json
.claude/worktrees/
.claude/.plan-write-ack
.claude/.session-state-path

# Session-state PPID scratch / legacy numbered handoffs (local only — never re-add)
# Stable handoff is docs/session-state-${BRANCH}.md (no trailing -PID)
docs/session-state-*-[0-9]*.md

# Environment & secrets (never commit)
.env
.env.*
.env.local
.env.*.local
*.pem
*.key
migration-dump.json

# Claude Code runtime state inside tools
tools/**/.claude/

# Catalog seeder — runtime output (never commit)
tools/catalog-seeder/output/pending-review.json
tools/catalog-seeder/output/pending-manual.json
tools/catalog-seeder/output/off-bulk-cache.csv.gz
tools/catalog-seeder/output/review-list.txt
tools/catalog-seeder/output/review-table.txt
tools/catalog-seeder/output/to-enrich.json
tools/catalog-seeder/output/*.csv.gz
tools/catalog-seeder/output/*.json.gz
tools/catalog-seeder/output/enriched.json
# seed-products.json IS committed after admin review — intentionally not ignored
tools/catalog-seeder/__pycache__/
tools/catalog-seeder/*.pyc

# MemPalace runtime data (vector DB, knowledge graph, config — never commit)
chroma.sqlite3
entities.json
mempalace.yaml
mine-progress.ps1

# Playwright MCP and UI Inspector artifacts (never commit)
.playwright-mcp/
.ui-inspector/

# Stray screenshots from browser automation (never commit)
*.png
*.jpg
*.jpeg

# System files
.DS_Store
Thumbs.db
.gstack/

backups/

# MemPalace
chroma.sqlite3
mine-progress.ps1

# One-time migration scripts
apply-*.js
.superpowers/

# Mobile audit credentials (local only)
.claude/reports/mobile-audit/.credentials.json

# Render audit credentials (local only)
.claude/reports/render-audit/.credentials.json

# Session manifests — per-session runtime state, never commit
.claude/sessions/

# GCM diagnostic log — dumps all env vars including secrets
gcm-diagnose.log

# Local MongoDB data (dev-only instance on :27018)
.mongo-local/

