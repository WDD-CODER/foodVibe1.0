{
  "name": "foodvibe-server",
  "version": "1.0.0",
  "description": "foodVibe Node/Express/MongoDB backend",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "cross-env NODE_ENV=production node --watch index.js",
