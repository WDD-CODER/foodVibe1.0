{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "Write([PROJECT_ROOT]/**)",
      "Write([CLAUDE_DATA_DIR]/**)",
      "Write([TEMP_DIR]/*)",
      "Edit([PROJECT_ROOT]/**)",
      "Edit([CLAUDE_DATA_DIR]/**)",
      "mcp__ide__getDiagnostics",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_hover",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_run_code",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_fill_form",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_navigate_back",
      "mcp__playwright__browser_resize",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_tabs",
      "mcp__mempalace__mempalace_status",
      "mcp__mempalace__mempalace_list_wings",
      "mcp__mempalace__mempalace_list_rooms",
      "mcp__mempalace__mempalace_get_taxonomy",
      "mcp__mempalace__mempalace_search",
      "mcp__mempalace__mempalace_check_duplicate",
      "mcp__mempalace__mempalace_get_aaak_spec",
      "mcp__mempalace__mempalace_add_drawer",
      "mcp__mempalace__mempalace_delete_drawer",
      "mcp__mempalace__mempalace_kg_query",
      "mcp__mempalace__mempalace_kg_add",
      "mcp__mempalace__mempalace_kg_invalidate",
      "mcp__mempalace__mempalace_kg_timeline",
      "mcp__mempalace__mempalace_kg_stats",
      "mcp__mempalace__mempalace_traverse",
      "mcp__mempalace__mempalace_find_tunnels",
      "mcp__mempalace__mempalace_graph_stats",
      "mcp__mempalace__mempalace_diary_write",
      "mcp__mempalace__mempalace_diary_read",
      "WebFetch",
      "WebSearch",
      "mcp__ide__getOpenEditors",
      "mcp__ide__getCurrentSelection"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash [PROJECT_ROOT]/scripts/branch-guard.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash [PROJECT_ROOT]/scripts/session-startup.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -File [PROJECT_ROOT]/.claude/reflect/tool-failure-hook.ps1"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python [PROJECT_ROOT]/scripts/context-monitor.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 [PROJECT_ROOT]/scripts/session-manifest-hook.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash [PROJECT_ROOT]/scripts/pre-compact-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash [PROJECT_ROOT]/scripts/handoff-check.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enableAllProjectMcpServers": false,
  "disabledMcpjsonServers": [
    "github",
    "context7"
  ]
}
